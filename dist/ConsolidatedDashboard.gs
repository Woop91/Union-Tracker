/**
 * Creates a gauge-style display (Google Sheets doesn't have native gauge)
 * @param {Sheet} sheet - The dashboard sheet
 * @private
 */
function createGaugeStyleChart_(sheet) {
  var winRate = sheet.getRange('D6').getValue() || '0%';
  var gaugeText = '═══════════════════════════════════════\n' +
                  '           🎯 WIN RATE GAUGE\n' +
                  '═══════════════════════════════════════\n\n' +
                  '                 ' + winRate + '\n\n' +
