    .setFontWeight('bold')
    .setFontSize(12)
    .setBackground(COLORS.CARD_DARK_BG)
    .setFontColor(COLORS.CARD_DARK_TEXT);
  sheet.getRange('A119:G119').merge();

  // Instructions
