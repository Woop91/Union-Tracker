          color: white;
        }
        .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 4px 15px rgba(124,58,237,0.4); }
        .btn-secondary {
          background: rgba(255,255,255,0.1);
          color: white;
        }
        .btn-secondary:hover { background: rgba(255,255,255,0.15); }
        .status-bar {
          margin-top: 20px;
