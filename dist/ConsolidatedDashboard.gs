 * @deprecated Use emailDashboardLink() in 11_SecureMemberDashboard.gs
 */
function emailDashboardLink_UIService_() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getActiveSheet();
