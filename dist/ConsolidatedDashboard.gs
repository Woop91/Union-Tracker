    // EMAIL VERIFICATION & QUARTERLY TRACKING
    // ══════════════════════════════════════════════════════════════════════════

    // Get email from form (try multiple common field names)
    var email = getFormValue_(responses, 'Email Address') ||
                getFormValue_(responses, 'Email') ||
