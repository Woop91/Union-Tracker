function getOrgNameFromConfig_() {
  try {
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var configSheet = ss.getSheetByName(SHEETS.CONFIG);
    if (configSheet) {
      var orgName = configSheet.getRange(3, CONFIG_COLS.ORG_NAME).getValue();
