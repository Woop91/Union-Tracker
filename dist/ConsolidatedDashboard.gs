    .setFontWeight('bold')
    .setBackground(COLORS.LIGHT_GRAY);
  sheet.getRange(3, dashStart, 1, 2).merge();

  // Response summary labels (values populated by syncSatisfactionValues)
  var responseSummary = [
    ['Total Responses', ''],
    ['Response Period', ''],
    ['', ''],
    ['📊 SECTION SCORES', ''],
    ['Section', 'Avg Score'],
    ['Overall Satisfaction', ''],
    ['Steward Rating', ''],
    ['Steward Access', ''],
    ['Chapter Effectiveness', ''],
