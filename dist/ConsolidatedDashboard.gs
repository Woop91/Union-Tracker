    '<div class="progress-bg"><div class="progress-fill" style="width:' + (satisfaction.responseCount > 0 ? Math.min(100, Math.round((satisfaction.responseCount / Math.max(1, coverage.memberCount)) * 100)) : 0) + '%"></div></div>' +
    '</div>' +
