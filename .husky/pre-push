#!/bin/sh
# Pre-push hook
# 1. OAuth scope change detection (all branches)
# 2. Full test suite gate (Main and staging only)

# Detect protected branches AND verify local is not behind origin
# (both checks share stdin, so consolidated into one loop)
echo "Fetching origin to verify local is up-to-date..."
git fetch origin --quiet || { echo "Fetch failed — check network."; exit 1; }

PROTECTED_PUSH=false
PROTECTED_BRANCHES=""
BEHIND_BLOCK=""
while read local_ref local_sha remote_ref remote_sha; do
  REMOTE_BRANCH="${remote_ref#refs/heads/}"
  case "$REMOTE_BRANCH" in
    Main|main|master|staging)
      PROTECTED_PUSH=true
      PROTECTED_BRANCHES="${PROTECTED_BRANCHES:+$PROTECTED_BRANCHES, }$REMOTE_BRANCH"
      ;;
  esac
  # Divergence check: origin ahead of local = non-fast-forward risk
  BEHIND=$(git rev-list --count "$local_sha..origin/$REMOTE_BRANCH" 2>/dev/null || echo 0)
  if [ "$BEHIND" -gt 0 ]; then
    BEHIND_BLOCK="${BEHIND_BLOCK}  origin/$REMOTE_BRANCH is $BEHIND commit(s) ahead of local.\n"
  fi
done

if [ -n "$BEHIND_BLOCK" ]; then
  echo ""
  echo "Push blocked — remote has commits you don't:"
  printf "$BEHIND_BLOCK"
  echo "Run: git pull --rebase origin <branch>"
  echo "(User may have uploaded files via GitHub web UI.)"
  exit 1
fi

echo "Running pre-push checks..."
echo ""

echo "[1/2] Checking for OAuth scope changes..."
node scripts/check-scope-change.js

if [ $? -ne 0 ]; then
  echo ""
  echo "Push blocked. See above for required action."
  echo "Use 'git push --no-verify' to bypass if you have already re-authorized."
  exit 1
fi

if [ "$PROTECTED_PUSH" = true ]; then
  echo ""
  echo "[2/2] Pushing to $PROTECTED_BRANCHES — running full test suite..."
  echo ""
  npm run test:unit

  if [ $? -ne 0 ]; then
    echo ""
    echo "Push to $PROTECTED_BRANCHES blocked: unit tests failed."
    echo "Fix failing tests before pushing to $PROTECTED_BRANCHES."
    exit 1
  fi
else
  echo ""
  echo "[2/2] Feature branch push — running deploy guards..."
  echo ""
  npx jest test/deploy-guards.test.js --no-coverage --bail --silent

  if [ $? -ne 0 ]; then
    echo ""
    echo "Feature branch push blocked: deploy guards failed."
    echo "Run 'npm run test:guards' for details."
    exit 1
  fi
fi

echo ""
echo "Pre-push checks passed."
