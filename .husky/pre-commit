#!/bin/sh
# Pre-commit hook - runs linting and build before allowing commit

echo "🔍 Running pre-commit checks..."
echo ""

# Run lint only (faster than full test)
npm run lint

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ Lint failed. Please fix errors before committing."
  exit 1
fi

echo ""
echo "✅ Pre-commit checks passed!"
