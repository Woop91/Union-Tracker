#!/bin/sh
# Pre-commit hook - runs lint-staged and build verification before allowing commit

echo "Running pre-commit checks..."
echo ""

# Step 1: Lint staged files only (faster than linting all files)
echo "[1/3] Linting staged files..."
npx lint-staged

if [ $? -ne 0 ]; then
  echo ""
  echo "Lint failed. Fix the errors above before committing."
  echo "  Run 'npm run lint:fix' to auto-fix some issues."
  exit 1
fi

# Step 2: Rebuild dist/ with prod settings (ensures dist/ is always in sync)
# TODO(human): Choose rebuild strategy for pre-commit hook
echo ""
echo "[2/3] Rebuilding dist/..."
node build.js --prod --minify > /dev/null

if [ $? -ne 0 ]; then
  echo ""
  echo "Build failed. Run 'npm run build:prod' to see details."
  exit 1
fi

# Auto-stage rebuilt dist/ so the commit includes correct prod output
git add dist/*.gs dist/*.html dist/appsscript.json > /dev/null

# Step 3: Deploy guards + SPA integrity (catches routing, auth, sheet, parity bugs)
echo ""
echo "[3/3] Running deploy guards..."
npx jest test/deploy-guards.test.js test/spa-integrity.test.js --no-coverage --bail --silent 2>&1
GUARD_EXIT=$?

if [ $GUARD_EXIT -ne 0 ]; then
  echo ""
  echo "Deploy guard tests failed. Run 'npm run test:guards' for details."
  exit 1
fi

echo ""
echo "Pre-commit checks passed."
