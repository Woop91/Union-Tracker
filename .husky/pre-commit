#!/bin/sh
# Pre-commit hook - runs lint-staged and build verification before allowing commit

echo "Running pre-commit checks..."
echo ""

# Step 1: Lint staged files only (faster than linting all files)
echo "[1/2] Linting staged files..."
npx lint-staged

if [ $? -ne 0 ]; then
  echo ""
  echo "Lint failed. Fix the errors above before committing."
  echo "  Run 'npm run lint:fix' to auto-fix some issues."
  exit 1
fi

# Step 2: Validate source syntax (without overwriting dist/)
# IMPORTANT: Uses --validate-only to prevent destroying the prod-minified dist.
# Previously this ran a full non-prod build which overwrote minified HTML with
# non-minified versions and re-added DevTools — causing silent deployment regressions.
echo ""
echo "[2/3] Validating source syntax..."
node build.js --validate-only > /dev/null 2>&1

if [ $? -ne 0 ]; then
  echo ""
  echo "Source validation failed. Run 'node build.js --validate-only' to see details."
  exit 1
fi

# Step 3: Deploy guards + SPA integrity (catches routing, auth, sheet, parity bugs)
echo ""
echo "[3/3] Running deploy guards..."
npx jest test/deploy-guards.test.js test/spa-integrity.test.js --no-coverage --bail 2>&1 | tail -5

if [ $? -ne 0 ]; then
  echo ""
  echo "Deploy guard tests failed. Run 'npm run test:guards' for details."
  exit 1
fi

echo ""
echo "Pre-commit checks passed."
