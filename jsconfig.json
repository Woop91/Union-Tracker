{
  "compilerOptions": {
    "checkJs": true,
    "target": "ES2020",
    "lib": ["ES2020"],
    "moduleResolution": "classic",
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.gs"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ],
  "typeAcquisition": {
    "enable": true,
    "include": [
      "@types/google-apps-script"
    ]
  }
}
