{
  "name": "union-steward-dashboard",
  "version": "4.25.2",
  "description": "Modular Union Steward Dashboard for Google Sheets",
  "main": "build.js",
  "scripts": {
    "build": "node build.js",
    "build:prod": "node build.js --prod",
    "lint": "eslint \"src/**/*.gs\"",
    "lint:fix": "eslint \"src/**/*.gs\" --fix",
    "test": "npm run lint && npm run build && jest --verbose",
    "test:unit": "jest --verbose",
    "coverage": "jest --coverage --verbose",
    "ci": "npm run clean && npm run lint && npm run build && npm run test:unit",
    "watch": "node build.js --watch",
    "clean": "node build.js --clean",
    "test:guards": "jest test/deploy-guards.test.js test/spa-integrity.test.js --verbose --no-coverage",
    "deploy": "npm run lint && npm run test:guards && npm run test:unit && npm run build:prod && clasp push",
    "open": "clasp open",
    "prepare": "husky",
    "sync-org-chart": "node scripts/sync-org-chart.js"
  },
  "keywords": [
    "google-apps-script",
    "google-sheets",
    "union",
    "grievance",
    "dashboard"
  ],
  "author": "Dashboard Team",
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@google/clasp": "^2.4.2",
    "@types/google-apps-script": "^1.0.83",
    "eslint": "^9.39.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.2.7"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Woop91/DDS-Dashboard"
  },
  "lint-staged": {
    "src/**/*.gs": [
      "eslint"
    ],
    "src/**/*.{gs,html}": [
      "npx jest test/deploy-guards.test.js --no-coverage --bail"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}